{
  "name": "clautel",
  "version": "1.0.1",
  "description": "Telegram bridge for Claude Code - use Claude from your phone",
  "type": "module",
  "bin": {
    "clautel": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "start": "tsx src/daemon.ts",
    "dev": "tsx watch src/daemon.ts",
    "cli": "tsx src/cli.ts",
    "test": "node --import tsx --test tests/*.test.ts",
    "keygen": "node scripts/keygen.mjs",
    "proxy:dev": "cd proxy && npx wrangler dev",
    "proxy:deploy": "cd proxy && npx wrangler deploy",
    "obfuscate": "node scripts/obfuscate.mjs",
    "prepublishOnly": "npm run build && npm run obfuscate"
  },
  "author": "Anas Nadeem",
  "license": "MIT",
  "homepage": "https://clautel.com",
  "keywords": [
    "clautel",
    "claude",
    "anthropic",
    "telegram",
    "claude-code",
    "ai",
    "mobile"
  ],
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.52",
    "dotenv": "^16",
    "grammy": "^1",
    "puppeteer": "^23.11.1"
  },
  "devDependencies": {
    "@types/node": "^22",
    "javascript-obfuscator": "^5.3.0",
    "tsx": "^4",
    "typescript": "^5"
  }
}
